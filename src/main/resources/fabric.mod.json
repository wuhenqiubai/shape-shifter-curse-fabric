{
  "schemaVersion": 1,
  "id": "shape-shifter-curse-unofficial",
  "version": "${version}",
  "name": "Shape Shifter Curse-Unofficial Port",
  "description": "An unofficial port of the mod that allows you to gradually transform into different vanilla creatures, each with unique models and animations.",
  "authors": [
    {
      "name": "onixary",
      "contact": {
        "github": "https://github.com/onixary"
      }
    },
    {
      "name": "XuHaoNan",
      "contact": {
        "github": "https://github.com/xu233333",
        "email": "18510478058@163.com"
      }
    }
  ],
  "contact": {
    "homepage": "https://www.curseforge.com/minecraft/mc-mods/shape-shifter-curse-unofficial-port",
    "sources": "https://github.com/wuhenqiubai/shape-shifter-curse-fabric",
    "issues": "https://github.com/wuhenqiubai/shape-shifter-curse-fabric/issues"
  },
  "contributors": [
    {
      "name": "MaxMobile-ru",
      "contact": {
        "github": "https://github.com/MaxMobile-ru"
      }
    },
    {
      "name": "wuhenqiubai",
      "contact": {
        "github": "https://github.com/wuhenqiubai"
      }
    },
    {
      "name": "ctmayton",
      "contact": {
        "github": "https://github.com/ctmayton"
      }
    },
    {
      "name": "OregonBanner",
      "contact": {
        "github": "https://github.com/OregonBanner"
      }
    },
    {
      "name": "solunareclipse1",
      "contact": {
        "github": "https://github.com/solunareclipse1"
      }
    },
    {
      "name": "Wonky",
      "contact": {
        "github": "https://github.com/wonky2"
      }
    }
  ],

  "license": "MIT",
  "icon": "assets/shape-shifter-curse/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "net.onixary.shapeShifterCurseFabric.ShapeShifterCurseFabric",
      "net.onixary.shapeShifterCurseFabric.integration.origins.Origins",
      "net.onixary.shapeShifterCurseFabric.player_form_render.OriginalFur"
    ],
    "client": [
      "net.onixary.shapeShifterCurseFabric.client.ShapeShifterCurseFabricClient",
      "net.onixary.shapeShifterCurseFabric.integration.origins.OriginsClient",
      "net.onixary.shapeShifterCurseFabric.player_form_render.OriginalFurClient"
    ],
    "modmenu": [
      "net.onixary.shapeShifterCurseFabric.config.ConfigIntegration"
    ],
    "cardinal-components-entity": [
      "net.onixary.shapeShifterCurseFabric.integration.origins.registry.ModComponents",
      "net.onixary.shapeShifterCurseFabric.player_form.ability.RegPlayerFormComponent",
      "net.onixary.shapeShifterCurseFabric.player_form.instinct.RegPlayerInstinctComponent",
      "net.onixary.shapeShifterCurseFabric.player_form.skin.RegPlayerSkinComponent",
      "net.onixary.shapeShifterCurseFabric.minion.RegPlayerMinionComponent",
      "net.onixary.shapeShifterCurseFabric.mana.RegManaComponent"
    ],
    "calio:ordered-resource-listener": [
      "net.onixary.shapeShifterCurseFabric.integration.origins.Origins"
    ]
  },

  "mixins": [
    "shape-shifter-curse.mixins.json",
    "origins.mixins.json",
    "originalfur.fabric.mixins.json",
    "ssc-misc.mixins.json"
  ],

  "accessWidener": "shape-shifter-curse.accesswidener",

  "custom": {
    "cardinal-components": [
      "origins:origin",
      "shape-shifter-curse:player_form",
      "shape-shifter-curse:player_instinct_component",
      "shape-shifter-curse:skin_settings",
      "shape-shifter-curse:player_minion_data",
      "shape-shifter-curse:mana"
    ],
    "ssc-accessory-priority": {
      "trinkets": {
        "priority": 1000,
        "depends": [
          "trinkets"
        ]
      },
      "curios": {
        "priority": 2000,
        "depends": [
          "curios"
        ]
      }
    }
  },

  "depends": {
    "java": ">=21",
    "fabricloader": ">=0.16.0",
    "fabric": ">=0.114.0",
    "minecraft": "1.21.1",
    "pehkui": ">=3.8.3",
    "satin": ">=2.0.0"
  },
  "breaks": {
    "origins": ">0.0.0",
    "enchantedlib": ">0.3.0",
    "optifabric": "*",
    "identity": "<1.14.2-beta",
    "azurelib": ">3.0.19",
    "azurelibarmor": "<2.0.12",
    "geckolib": "<4.7.0"
  },
  "recommends": {
    "firstperson": "*",
    "trinkets": ">=3.10.0"
  }
}
