{
  "schemaVersion": 1,
  "id": "shape-shifter-curse",
  "version": "${version}",

  "name": "Shape Shifter Curse",
  "description": "a mod which focus on gradually transform into different forms based on vanilla creatures, gaining their unique abilities and drawbacks",
  "authors": [
    {
      "name": "onixary",
      "contact": {
